<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>QR Attendance - Public Demo (View Only)</title>

<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@600&family=Roboto:wght@400;500&display=swap" rel="stylesheet">

<script src="https://www.gstatic.com/firebasejs/8.10.1/firebase-app.js"></script>
<script src="https://www.gstatic.com/firebasejs/8.10.1/firebase-firestore.js"></script>

<script src="https://cdn.jsdelivr.net/npm/qrcodejs/qrcode.min.js"></script>

<style>
body{
  font-family:'Roboto',sans-serif;
  background:#0F172A;
  color:#F8FAFC;
  padding:30px;
  margin:0;
}

h1{ font-family:'Orbitron'; color:#F97316; margin-bottom:20px; }
h2{ color:#FBBF24; }
h3{ color:#FACC15; }

.container{
  background:#1E293B;
  padding:25px;
  border-radius:12px;
  margin-bottom:25px;
}

input{
  width:260px;
  padding:10px;
  margin:6px;
  border-radius:6px;
  border:1px solid #334155;
  background:#0F172A;
  color:white;
}

button{
  padding:10px 15px;
  border:none;
  border-radius:6px;
  background:#F97316;
  color:white;
  cursor:pointer;
  margin:4px 0;
}

table{
  width:100%;
  border-collapse:collapse;
  margin-top:15px;
  background:#0F172A;
}

th{
  background:#F97316;
  padding:12px;
}

td{
  padding:12px;
  border-bottom:1px solid #334155;
}

#studentTable div{
  background:white;
  padding:8px;
  border-radius:8px;
  display:inline-block;
  border:2px solid #F97316;
}

/* BANNER */
.banner{
  background:#F97316;
  padding:10px;
  border-radius:8px;
  margin-bottom:20px;
  font-weight:bold;
}
</style>
</head>

<body>

<div class="banner">
PUBLIC DEMO MODE - VIEW ONLY
</div>

<h1>QR Attendance System</h1>

<!-- STUDENTS -->
<div class="container">
<h2>Students</h2>


<button id="toggleBtn" onclick="toggleStudents()">Hide Students</button>
<br><br>

<input id="searchCampus" placeholder="Search Campus or Name">
<button onclick="searchStudents()">Search</button>
<button onclick="loadStudents()">Show All</button>

<div id="studentsContainer">
<table>
<thead>
<tr>
<th>ID</th>
<th>Name</th>
<th>Course</th>
<th>Section</th>
<th>Campus</th>
<th>QR</th>
</tr>
</thead>
<tbody id="studentTable"></tbody>
</table>
</div>
</div>

<!-- ATTENDANCE -->
<div class="container">
<h2>Attendance Records</h2>

<input type="date" id="filterDate">
<button onclick="filterAttendance()">Filter by Date</button>
<button onclick="loadAll()">Show All</button>

<h3>Morning Attendance</h3>
<table>
<thead>
<tr>
<th>ID</th><th>Name</th><th>Section</th><th>Campus</th><th>Date</th><th>Time</th><th>Status</th>
</tr>
</thead>
<tbody id="morningAttendanceTable"></tbody>
</table>

<h3>Afternoon Attendance</h3>
<table>
<thead>
<tr>
<th>ID</th><th>Name</th><th>Section</th><th>Campus</th><th>Date</th><th>Time</th><th>Status</th>
</tr>
</thead>
<tbody id="afternoonAttendanceTable"></tbody>
</table>
</div>

<script>

/* FIREBASE */
var firebaseConfig={
  apiKey:"YOUR_API_KEY",
  authDomain:"attsheet-f23a7.firebaseapp.com",
  projectId:"attsheet-f23a7"
};

firebase.initializeApp(firebaseConfig);
var db=firebase.firestore();

/* SHOW/HIDE STUDENTS */
let studentsVisible=true;

function toggleStudents(){
  const container=document.getElementById("studentsContainer");
  const button=document.getElementById("toggleBtn");

  if(studentsVisible){
    container.style.display="none";
    button.innerText="Show Students";
    studentsVisible=false;
  }else{
    container.style.display="block";
    button.innerText="Hide Students";
    studentsVisible=true;
  }
}

/* LOAD STUDENTS */
function loadStudents(){
  db.collection("students").onSnapshot(snapshot=>{
    let table="";

    snapshot.forEach(doc=>{
      let d=doc.data();
      table+=`
      <tr>
        <td>${d.studentID}</td>
        <td>${d.name}</td>
        <td>${d.course}</td>
        <td>${d.section}</td>
        <td>${d.campus}</td>
        <td><div id="qr${d.studentID}"></div></td>
      </tr>`;
    });

    document.getElementById("studentTable").innerHTML=table;

    snapshot.forEach(doc=>{
      let d=doc.data();
      new QRCode(document.getElementById("qr"+d.studentID),{
        text:d.studentID,
        width:70,
        height:70
      });
    });
  });
}

/* SEARCH */
function searchStudents(){
  let keyword=document.getElementById("searchCampus").value.toLowerCase();

  db.collection("students").get().then(snapshot=>{
    let table="";

    snapshot.forEach(doc=>{
      let d=doc.data();

      if(d.name.toLowerCase().includes(keyword) ||
         d.campus.toLowerCase().includes(keyword)){

        table+=`
        <tr>
          <td>${d.studentID}</td>
          <td>${d.name}</td>
          <td>${d.course}</td>
          <td>${d.section}</td>
          <td>${d.campus}</td>
          <td><div id="qr${d.studentID}"></div></td>
        </tr>`;
      }
    });

    document.getElementById("studentTable").innerHTML=table;

    snapshot.forEach(doc=>{
      let d=doc.data();

      if(d.name.toLowerCase().includes(keyword) ||
         d.campus.toLowerCase().includes(keyword)){

        new QRCode(document.getElementById("qr"+d.studentID),{
          text:d.studentID,
          width:70,
          height:70
        });
      }
    });
  });
}

/* ATTENDANCE */
function loadAll(){
  db.collection("attendance").onSnapshot(snapshot=>{
    let m="", a="";

    snapshot.forEach(doc=>{
      let d=doc.data();

      let row=`
      <tr>
        <td>${d.studentID}</td>
        <td>${d.name}</td>
        <td>${d.section}</td>
        <td>${d.campus}</td>
        <td>${d.date}</td>
        <td>${d.time}</td>
        <td>${d.status}</td>
      </tr>`;

      if(d.session==="Morning") m+=row;
      else a+=row;
    });

    document.getElementById("morningAttendanceTable").innerHTML=m;
    document.getElementById("afternoonAttendanceTable").innerHTML=a;
  });
}

/* FILTER */
function filterAttendance(){
  let selected=document.getElementById("filterDate").value;
  if(!selected){ alert("Select date"); return; }

  let m="", a="";

  db.collection("attendance").get().then(snapshot=>{
    snapshot.forEach(doc=>{
      let d=doc.data();
      let fDate=new Date(d.date).toISOString().split("T")[0];

      if(fDate===selected){
        let row=`
        <tr>
          <td>${d.studentID}</td>
          <td>${d.name}</td>
          <td>${d.section}</td>
          <td>${d.campus}</td>
          <td>${d.date}</td>
          <td>${d.time}</td>
          <td>${d.status}</td>
        </tr>`;

        if(d.session==="Morning") m+=row;
        else a+=row;
      }
    });

    document.getElementById("morningAttendanceTable").innerHTML=m;
    document.getElementById("afternoonAttendanceTable").innerHTML=a;
  });
}

/* INIT */
loadStudents();
loadAll();

</script>

</body>
</html>
